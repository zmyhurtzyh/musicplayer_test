<?xml version="1.0" encoding="utf-8"?>
<!-- 封面子页（ViewPager2 第一页）：黑胶唱片 + 唱针动画 + 歌曲信息 -->
<!-- 核心布局：FrameLayout 包裹垂直 LinearLayout，中心放置 340dp 唱片+唱针组合区域 -->
<!-- 关键交互：播放时唱片旋转动画、唱针摆动动画；点击封面无特殊交互，需滑动切换到歌词页 -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- 唱片 + 唱针容器：FrameLayout 叠放唱片底盘和唱针，唱针定位在右上角 -->
        <FrameLayout
            android:layout_width="340dp"
            android:layout_height="340dp"
            android:layout_gravity="center_horizontal">

            <!-- 唱片旋转容器：播放时整体绕中心旋转，包含黑胶底盘和圆形封面 -->
            <FrameLayout
                android:id="@+id/disc_container"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:elevation="12dp">

                <!-- 黑胶唱片底盘：深色圆盘 + 同心圆纹理 + 中心红色标签，纯 drawable 实现 -->
                <View
                    android:id="@+id/vinyl_disc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/vinyl_disc" />

                <!-- 圆形封面图：居中裁剪显示专辑封面，圆形遮罩裁切 -->
                <ImageView
                    android:id="@+id/disc_cover"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_cover_mask"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_default_cover"
                    android:contentDescription="@null" />
            </FrameLayout>

            <!-- 唱针：定位在右上角，播放时以支点为轴心旋转摆入唱片区域，暂停时摆出 -->
            <ImageView
                android:id="@+id/tonearm"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-30dp"
                android:layout_marginEnd="-30dp"
                android:elevation="16dp"
                android:src="@drawable/ic_tonearm"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- 歌曲名称：大号加粗白色文字，带阴影增强深色背景下的可读性 -->
        <TextView
            android:id="@+id/disc_song_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:shadowColor="#000000"
            android:shadowRadius="6"
            android:shadowDx="0"
            android:shadowDy="2"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 歌手名称：次要信息，浅色小号文字 -->
        <TextView
            android:id="@+id/disc_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:textColor="@color/text_white_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
