<?xml version="1.0" encoding="utf-8"?>
<!-- 登录/注册页面：用户身份认证入口，支持登录和注册两种模式切换 -->
<!-- 核心布局：垂直 LinearLayout，顶部品牌展示区（渐变背景 + Logo）+ 输入表单区（用户名/密码/昵称）+ 操作按钮 -->
<!-- 关键交互：登录按钮提交认证、切换链接在登录/注册模式间切换、昵称输入框仅在注册模式显示 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_login_gradient"
        android:gravity="center"
        android:orientation="vertical">

        <!-- 应用 Logo 图标：圆形白色背景衬托 -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/bg_logo_circle"
            android:contentDescription="@null" />

        <!-- 应用名称 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 应用副标题：半透明白色，辅助说明 -->
        <TextView
            android:id="@+id/login_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/login_subtitle"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 输入表单区域：包含昵称（仅注册）、用户名、密码输入框及登录按钮和模式切换 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="36dp">

        <!-- 昵称输入框：仅在注册模式下显示（visibility=gone），登录时动态设为 visible -->
        <EditText
            android:id="@+id/login_nickname"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edit_rounded"
            android:hint="@string/hint_nickname"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 昵称输入框的占位分隔：注册模式下用于撑开间距 -->
        <View
            android:id="@+id/login_nickname_divider"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- 用户名输入框：登录和注册模式均显示 -->
        <EditText
            android:id="@+id/login_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_edit_rounded"
            android:hint="@string/hint_username"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- 密码输入框：密文显示输入内容 -->
        <EditText
            android:id="@+id/login_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_edit_rounded"
            android:hint="@string/hint_password"
            android:inputType="textPassword"
            android:maxLines="1"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp" />

        <!-- 登录/注册按钮：渐变红色背景，点击提交认证请求 -->
        <Button
            android:id="@+id/login_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_btn_gradient"
            android:elevation="4dp"
            android:text="@string/action_login"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- 切换登录/注册模式链接：点击后切换表单状态和按钮文字 -->
        <TextView
            android:id="@+id/login_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:text="@string/action_switch_to_register"
            android:textColor="@color/netease_red"
            android:textSize="13sp" />

        <!-- 错误提示文本：认证失败时显示错误信息，默认隐藏 -->
        <TextView
            android:id="@+id/login_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:textColor="@color/favorite_red"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
