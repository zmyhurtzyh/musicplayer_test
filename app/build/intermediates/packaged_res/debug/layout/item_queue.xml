<?xml version="1.0" encoding="utf-8"?>
<!-- 播放队列列表项：展示播放队列中的单首歌曲，含序号/播放指示、封面、信息和删除按钮 -->
<!-- 核心布局：水平 LinearLayout，序号/播放图标（叠放）+ 封面 + 标题/歌手 + 删除按钮 -->
<!-- 关键交互：点击整行切换播放该歌曲、当前播放项显示播放图标替代序号、右侧删除按钮从队列移除 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- 序号/播放图标容器：FrameLayout 叠放序号文字和播放图标，当前播放项显示图标替代序号 -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="match_parent">

        <!-- 序号文字：非当前播放项显示位置序号 -->
        <TextView
            android:id="@+id/queue_index"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/text_hint"
            android:textSize="13sp" />

        <!-- 播放中图标：当前正在播放的歌曲显示音乐图标替代序号，默认隐藏 -->
        <ImageView
            android:id="@+id/queue_playing_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_stat_music"
            android:visibility="gone"
            android:contentDescription="@null" />
    </FrameLayout>

    <!-- 封面缩略图：显示歌曲专辑封面 -->
    <ImageView
        android:id="@+id/queue_cover"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- 标题/歌手区域：歌曲名称（主）+ 歌手名（副），垂直排列 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- 歌曲标题 -->
        <TextView
            android:id="@+id/queue_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <!-- 歌手名称 -->
        <TextView
            android:id="@+id/queue_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 删除按钮：点击将该歌曲从播放队列中移除 -->
    <ImageView
        android:id="@+id/queue_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="center"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_clear"
        android:contentDescription="@null" />
</LinearLayout>
