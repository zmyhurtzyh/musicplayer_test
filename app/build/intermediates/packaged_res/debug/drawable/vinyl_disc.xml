<?xml version="1.0" encoding="utf-8"?>
<!-- 黑胶唱片视觉：多层 layer-list 模拟真实黑胶唱片的外观 -->
<!-- 视觉效果：深黑外圈 + 4圈同心圆纹理（模拟唱片沟槽）+ 中心红色标签圆，整体 280dp 圆形 -->
<!-- 使用场景：封面子页（page_disc）中 vinyl_disc View 的背景，播放时随 disc_container 一起旋转 -->
<!-- 颜色含义：外圈 #050505（极深黑）、纹理 #2A2A2A/#252525/#1F1F1F/#1A1A1A（微亮同心圆沟槽）、中心 #C20C0C（网易红标签） -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外圈：深黑色圆形底盘，1dp 描边增加边缘质感 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#050505" />
            <stroke android:width="1dp" android:color="#1A1A1A" />
        </shape>
    </item>
    <!-- 纹理 1：最外圈沟槽，距边缘 6dp，0.5dp 描边 -->
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="0.5dp" android:color="#2A2A2A" />
        </shape>
    </item>
    <!-- 纹理 2：第二圈沟槽，距边缘 16dp -->
    <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="0.5dp" android:color="#252525" />
        </shape>
    </item>
    <!-- 纹理 3：第三圈沟槽，距边缘 28dp -->
    <item android:left="28dp" android:top="28dp" android:right="28dp" android:bottom="28dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="0.5dp" android:color="#1F1F1F" />
        </shape>
    </item>
    <!-- 纹理 4：第四圈沟槽，距边缘 40dp -->
    <item android:left="40dp" android:top="40dp" android:right="40dp" android:bottom="40dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="0.5dp" android:color="#1A1A1A" />
        </shape>
    </item>
    <!-- 中心标签：红色圆形标签，模拟唱片中心区域，1dp 亮红描边增加质感 -->
    <item android:left="60dp" android:top="60dp" android:right="60dp" android:bottom="60dp">
        <shape android:shape="oval">
            <solid android:color="#C20C0C" />
            <stroke android:width="1dp" android:color="#E84040" />
        </shape>
    </item>
</layer-list>
