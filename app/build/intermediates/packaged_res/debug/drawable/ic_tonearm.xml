<?xml version="1.0" encoding="utf-8"?>
<!-- 唱针矢量图：模拟黑胶唱片机的唱针臂，包含臂体、支点和针尖 -->
<!-- 视觉效果：金属质感唱针臂（灰白渐变三层线条）+ 支点（外灰内深渐变圆）+ 红色针尖，180dp 方形 -->
<!-- 使用场景：封面子页（page_disc）中唱针 ImageView 的 src，播放时绕支点旋转摆入唱片 -->
<!-- 颜色含义：臂阴影 #40000000（25%黑色）、臂体 #C8C8C8（浅灰金属）、高光 #FFFFFF（白色反光）、支点 #A0A0A0→#707070→#404040（由外到内渐深）、针尖 #E84040（亮红，品牌色） -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="180dp"
    android:height="180dp"
    android:viewportWidth="180"
    android:viewportHeight="180">
    <!-- 唱针臂阴影：8dp 粗黑色线条，在臂体下方产生阴影效果 -->
    <path
        android:strokeColor="#40000000"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M155,25 L75,105" />
    <!-- 唱针臂主体：6dp 粗浅灰色线条，模拟金属臂杆 -->
    <path
        android:strokeColor="#C8C8C8"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M155,25 L75,105" />
    <!-- 唱针臂高光：2dp 粗白色线条，偏移2dp 产生金属反光效果 -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M153,23 L73,103" />
    <!-- 支点外圈：14dp 半径灰色圆，唱针旋转的轴心外层 -->
    <path
        android:fillColor="#A0A0A0"
        android:pathData="M155,25 m-14,0 a14,14 0,1 0,28 0 a14,14 0,1 0,-28 0" />
    <!-- 支点内圈：8dp 半径中灰色圆，轴心中间层 -->
    <path
        android:fillColor="#707070"
        android:pathData="M155,25 m-8,0 a8,8 0,1 0,16 0 a8,8 0,1 0,-16 0" />
    <!-- 支点中心：3dp 半径深灰色圆，轴心最内层 -->
    <path
        android:fillColor="#404040"
        android:pathData="M155,25 m-3,0 a3,3 0,1 0,6 0 a3,3 0,1 0,-6 0" />
    <!-- 唱针尖连接段：4dp 粗灰色短线，连接臂体与针尖 -->
    <path
        android:strokeColor="#909090"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M75,105 L65,115" />
    <!-- 唱针尖：5dp 半径红色圆，模拟唱片针头的品牌色点缀 -->
    <path
        android:fillColor="#E84040"
        android:pathData="M65,115 m-5,0 a5,5 0,1 0,10 0 a5,5 0,1 0,-10 0" />
</vector>
