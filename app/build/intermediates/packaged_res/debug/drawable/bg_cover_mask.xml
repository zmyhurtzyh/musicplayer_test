<?xml version="1.0" encoding="utf-8"?>
<!-- 圆形封面遮罩：深灰圆形 + 半透明白色描边，作为唱片中心封面图的背景/裁切层 -->
<!-- 视觉效果：圆形深色底 + 1dp 半透明白色边框，使方形封面图裁切为圆形，与唱片底盘视觉融合 -->
<!-- 使用场景：封面子页（page_disc）中 disc_cover ImageView 的 background，将专辑封面裁切为圆形 -->
<!-- 颜色含义：填充 #1A1A1A（深灰底色，与唱片底盘协调）、描边 #33FFFFFF（20%白色半透明边框） -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#1A1A1A" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
